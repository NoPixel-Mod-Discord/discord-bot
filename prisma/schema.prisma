generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["referentialIntegrity"]
}

datasource db {
  provider             = "mysql"
  url                  = env("DATABASE_URL")
  referentialIntegrity = "prisma"
}

model Alts {
  id       Int           @id @default(autoincrement()) @db.UnsignedInt
  altVenue Alts_altVenue
  altId    String        @db.VarChar(255)
  userId   String        @db.VarChar(255)
}

model Mods {
  id         Int          @id @default(autoincrement()) @db.UnsignedInt
  userId     String       @db.VarChar(255)
  createdAt  DateTime     @db.DateTime(0)
  isVerified Boolean
  modType    Mods_modType
}

model Bans {
  id          Int           @id @default(autoincrement()) @db.UnsignedInt
  banTime     DateTime      @db.DateTime(0)
  banVenue    Bans_banVenue
  userId      String        @db.VarChar(255)
  isBanned    Boolean
  streamerId  String        @db.VarChar(255)
  moderatorId String        @db.VarChar(255)
  reason      String        @db.VarChar(255)
  evidence    String        @db.VarChar(255)
}

model Streamers {
  id         Int                  @id @default(autoincrement()) @db.UnsignedInt
  userId     String               @db.VarChar(255)
  lastOnline DateTime             @db.DateTime(0)
  channelId  String               @db.VarChar(255)
  streamType Streamers_streamType
}

model Users {
  id        Int         @id @default(autoincrement()) @db.UnsignedInt
  userId    String      @unique(map: "users_userid_unique") @db.VarChar(255)
  venue     Users_venue
  createdAt DateTime    @db.DateTime(0)
  updatedAt DateTime    @db.DateTime(0)
}

enum Alts_altVenue {
  twitch
  facebook
  youtube
  discord
}

enum Bans_banVenue {
  twitch
  facebook
  youtube
  discord
}

enum Mods_modType {
  twitch
  facebook
  youtube
  discord
}

enum Streamers_streamType {
  twitch
  facebook
  youtube
  discord
}

enum Users_venue {
  twitch
  facebook
  youtube
  discord
}
