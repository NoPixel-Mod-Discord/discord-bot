{
  "name": "discord-bot",
  "description": "No-Pixel Mods Discord bot for mod/streamer verification and manual/automatic ban logging.",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "git@github.com:NoPixel-Mod-Discord/discord-bot.git",
  "author": "NoPixel-Mod-Discord",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "nodemon src/index.js",
    "bot-dev": "nodemon src/bot.js",
    "check-format": "prettier --check .",
    "check-lint": "eslint . --ext js",
    "format": "prettier --write .",
    "lint": "eslint . --ext js --fix",
    "check": "check-format && check-lint",
    "fix": "npm run format && npm run lint",
    "start": "node src/index.js",
    "prepare": "husky install"
  },
  "devDependencies": {
    "eslint": "^8.18.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "lint-staged": "^13.0.2",
    "nodemon": "^2.0.16",
    "prettier": "^2.7.1",
    "prisma": "^3.15.2"
  },
  "dependencies": {
    "@discordjs/builders": "^0.15.0",
    "@discordjs/rest": "^0.5.0",
    "@prisma/client": "^3.15.2",
    "discord-api-types": "^0.34.0",
    "discord.js": "^13.8.0",
    "dotenv": "^16.0.1",
    "mysql": "^2.18.1",
    "node-fetch": "^2.6.7",
    "node-html-parser": "^5.3.3",
    "tmi.js": "^1.8.5"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*": "prettier --write"
  }
}
